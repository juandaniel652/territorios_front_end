{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/login/index.html" },
    { "source": "/login", "destination": "/login/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    }
  ]
}
