{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/register", "dest": "/login/register.html" },
    { "src": "/login", "dest": "/login/index.html" },
    { "src": "/dashboard", "dest": "/dashboard/index.html" },
    { "src": "/assets/(.*)", "headers": { "cache-control": "public, max-age=31536000, immutable" }, "continue": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}