{
  "version": 2,
  "name": "territorios-albertina",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/login/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/frontend/dashboard/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/frontend/dashboard/$1"
    }
  ]
}